<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Displays real-time data for 3 sensors in separate cards:
    1. Accelerometer (X, Y, Z)
    2. Light Sensor (lux)
    3. Proximity Sensor (cm)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Page Title ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡 Sensor Data Monitor"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live readings update in real-time"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- ════════════════════════════════════ -->
        <!--        ACCELEROMETER CARD           -->
        <!-- ════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📳"
                        android:textSize="28sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accelerometer"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>

                        <TextView
                            android:id="@+id/tvAccelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checking..."
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginBottom="12dp"/>

                <!-- X axis -->
                <TextView
                    android:id="@+id/tvAccelX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="X:  -- m/s²"
                    android:textSize="17sp"
                    android:fontFamily="monospace"
                    android:textColor="@android:color/holo_red_dark"
                    android:layout_marginBottom="6dp"/>

                <!-- Y axis -->
                <TextView
                    android:id="@+id/tvAccelY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Y:  -- m/s²"
                    android:textSize="17sp"
                    android:fontFamily="monospace"
                    android:textColor="@android:color/holo_green_dark"
                    android:layout_marginBottom="6dp"/>

                <!-- Z axis -->
                <TextView
                    android:id="@+id/tvAccelZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Z:  -- m/s²"
                    android:textSize="17sp"
                    android:fontFamily="monospace"
                    android:textColor="@android:color/holo_blue_dark"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ════════════════════════════════════ -->
        <!--          LIGHT SENSOR CARD          -->
        <!-- ════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="28sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Light Sensor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>

                        <TextView
                            android:id="@+id/tvLightStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checking..."
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginBottom="12dp"/>

                <!-- Lux value -->
                <TextView
                    android:id="@+id/tvLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-- lux"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvLightDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for data..."
                    android:textSize="15sp"
                    android:gravity="center"
                    android:textColor="?android:attr/textColorSecondary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ════════════════════════════════════ -->
        <!--        PROXIMITY SENSOR CARD        -->
        <!-- ════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📏"
                        android:textSize="28sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Proximity Sensor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"/>

                        <TextView
                            android:id="@+id/tvProximityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checking..."
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginBottom="12dp"/>

                <!-- Distance value -->
                <TextView
                    android:id="@+id/tvProximity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-- cm"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Near / Far description -->
                <TextView
                    android:id="@+id/tvProximityDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for data..."
                    android:textSize="15sp"
                    android:gravity="center"
                    android:textColor="?android:attr/textColorSecondary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>