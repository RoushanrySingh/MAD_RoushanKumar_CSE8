<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_settings.xml
    Settings screen — currently provides a Dark / Light theme toggle.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <!-- Section heading -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Appearance"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="16dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginBottom="24dp"/>

    <!-- Toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Moon icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="28sp"
            android:layout_marginEnd="16dp"/>

        <!-- Label column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark Mode"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvThemeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light Mode (ON)"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"/>

        </LinearLayout>

        <!-- Toggle switch -->
        <Switch
            android:id="@+id/switchDarkMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Description text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Switch between Light and Dark themes. Your preference is saved and applied every time you open the app."
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginTop="16dp"/>

</LinearLayout>