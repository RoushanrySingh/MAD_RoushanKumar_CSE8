<?xml version="1.0" encoding="utf-8"?>
<!--
    res/xml/file_paths.xml
    Required by FileProvider to know which directories it can share URIs from.

    external-path: grants access to any path on external storage
    This allows the camera to write the photo to Pictures/PhotoGalleryApp/
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <external-path
        name="my_images"
        path="." />
</paths>
